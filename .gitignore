# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS
.DS_Store

# ---------------------------------------------------------------------------
# Financial data: belt-and-suspenders denials
# ---------------------------------------------------------------------------
# 1. Default-deny under clients/<client>/, allowlist only the artefacts
#    that should be tracked (configs, mapping, docs, chart specs).
clients/*/*
!clients/*/config.yaml
!clients/*/mapping.yaml
!clients/*/model_rules.yaml
!clients/*/model_gates.yaml
!clients/*/*.md
!clients/*/chart_specs/
clients/*/chart_specs/*
!clients/*/chart_specs/*.json
!clients/*/chart_specs/*.md
!clients/*/one_offs/
clients/*/one_offs/*
!clients/*/one_offs/*.py
!clients/*/one_offs/*.md
# loansdb: self-contained loan-book tool (py + generated html + notebook + docs) — tracked
!clients/*/loansdb/
!clients/*/loansdb/*

# 2. Repo-wide deny for sensitive file types so an accidentally-misplaced
#    file outside clients/ still can't be committed. If a legitimate need
#    arises (e.g. test fixtures), allowlist the specific path explicitly.
*.xlsx
*.xls
*.xlsm
*.csv
*.pdf
*.pptx
*.db
*.sqlite
*.sqlite3

# 3. Archive of deprecated client trees. Deleted 2026-06-16 (the old dashboard
#    project lives on at github.com/aivan33/almacena-ledger). Stay fully ignored
#    so a stray re-copy can never stage an embedded repo or local secrets.
_archive/
