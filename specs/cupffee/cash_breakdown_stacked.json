{
  "chart_id": "cash_breakdown_stacked",
  "client": "cupffee",
  "title": "Cash Breakdown EUR '000",
  "chart_type": "stacked_bar",
  "source": "custom",
  "period": {"kind": "ltm", "months": 12},

  "data": [
    {
      "label": "Cash from Clients",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": "Cash from Sales",
        "scenario": "actual"
      }
    },
    {
      "label": "Materials",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": "Purchased direct material",
        "scenario": "actual"
      }
    },
    {
      "label": "Other (Op)",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": [
          "Cash paid to suppliers",
          "Payments to personnel (excl. R&D cap)",
          "VAT & Refunds",
          "Taxes paid / redeemed, net",
          "Other payments/proceeds, net (taxes, FX gains/losses)"
        ],
        "scenario": "actual"
      }
    },
    {
      "label": "PPE / Investing",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Investing Activities",
        "scenario": "actual"
      }
    },
    {
      "label": "Financial Inflows",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Financing Activities",
        "scenario": "actual"
      }
    }
  ],

  "axes": {
    "y": {"format": "EUR_thousands"}
  },

  "notes": "Five deck-style stacked categories: Cash from Clients (Op/Cash from Sales), Materials (Op/Purchased direct material), Other (remaining Op subgroups summed: suppliers, personnel, VAT, taxes, other), PPE/Investing (full CF Inv), Financial Inflows (full CF Fin)."
}
