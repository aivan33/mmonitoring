{
  "chart_id": "revenue_actual_rolling_budget",
  "client": "cupffee",
  "title": "Revenue — Actual + Rolling Budget 2026",
  "chart_type": "bar_projection",
  "source": "custom",
  "period": {"kind": "full_year", "year": 2026},

  "data": [
    {
      "label": "Actual",
      "query": {
        "kind": "trend",
        "data": "Sales",
        "scenario": "actual",
        "year": 2026
      }
    },
    {
      "label": "Rolling Budget",
      "query": {
        "kind": "trend",
        "data": "Sales",
        "scenario": "realistic",
        "year": 2026
      }
    }
  ],

  "axes": {
    "y": {"format": "EUR_thousands"}
  },

  "notes": "Two-series bar_projection: prefer actual where present (Jan-Mar 2026), fall back to realistic budget for Apr-Dec 2026. Single bar per month, two colours."
}
