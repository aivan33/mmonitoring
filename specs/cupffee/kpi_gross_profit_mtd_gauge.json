{
  "chart_id": "kpi_gross_profit_mtd_gauge",
  "client": "cupffee",
  "title": "Gross Profit MTD",
  "chart_type": "gauge",
  "source": "custom",
  "period": {"kind": "current_month"},

  "data": [
    {
      "label": "Actual",
      "query": {
        "kind": "trend",
        "data": ["Sales", "Cost of Sales"],
        "signs": [1, -1],
        "scenario": "actual"
      }
    },
    {
      "label": "Budget (Realistic)",
      "query": {
        "kind": "trend",
        "data": ["Sales", "Cost of Sales"],
        "signs": [1, -1],
        "scenario": "realistic"
      }
    }
  ],

  "gauge": {"start": 0},

  "notes": "Gross Profit = Sales − Cost of Sales (MTD). Production Costs is opex, not COGS — verified Dec 2025: Sales 124K - CoS 44.5K = 79.5K matches deck."
}
