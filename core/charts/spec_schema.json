{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chart spec",
  "type": "object",
  "required": ["chart_id", "client", "title", "chart_type", "source", "period", "data"],
  "additionalProperties": false,
  "properties": {
    "chart_id": {"type": "string", "minLength": 1},
    "client":   {"type": "string", "minLength": 1},
    "title":    {"type": "string", "minLength": 1},
    "chart_type": {
      "enum": ["line", "bar", "stacked_bar", "donut", "kpi_card", "waterfall",
               "table", "gauge", "clustered_bar", "bar_with_line",
               "lines_with_bar", "bar_projection", "donut_pair"]
    },
    "gauge": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {"oneOf": [{"type": "number"}, {"const": "previous_period"}]}
      }
    },
    "source":   {"enum": ["custom", "platform"]},
    "platform_export": {"type": ["string", "null"]},
    "entity":   {"type": ["string", "null"]},
    "notes":    {"type": "string"},
    "value_format": {"enum": ["eur", "count", "percent_decimal", "days", "ratio"]},
    "show_totals": {"type": "boolean"},
    "display_order": {"type": "integer"},

    "period": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind":   {"enum": ["current_month", "ytd", "ltm", "month_offset",
                            "full_year", "explicit", "range"]},
        "offset": {"type": "integer"},
        "year":   {"type": "integer"},
        "month":  {"type": "integer", "minimum": 1, "maximum": 12},
        "start":  {"type": "string"},
        "end":    {"type": "string"},
        "months": {"type": "integer", "minimum": 1}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "full_year"}}},
         "then": {"required": ["year"]}},
        {"if": {"properties": {"kind": {"const": "explicit"}}},
         "then": {"required": ["year", "month"]}},
        {"if": {"properties": {"kind": {"const": "month_offset"}}},
         "then": {"required": ["offset"]}},
        {"if": {"properties": {"kind": {"const": "range"}}},
         "then": {"required": ["start", "end"]}}
      ]
    },

    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "query"],
        "additionalProperties": false,
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "display_sign": {"enum": [1, -1]},
          "query": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": false,
            "properties": {
              "kind":     {"enum": ["trend", "value", "aggregation", "projection",
                                    "kpi_trend", "kpi_value"]},
              "data":     {"oneOf": [
                {"type": "string"},
                {"type": "array", "items": {"type": "string"}, "minItems": 1}
              ]},
              "grp":      {"oneOf": [
                {"type": ["string", "null"]},
                {"type": "array", "items": {"type": "string"}, "minItems": 1}
              ]},
              "subgroup": {"type": ["string", "null"]},
              "scenario": {"enum": ["actual", "pessimistic", "realistic", "optimistic"]},
              "fallback_scenario": {"enum": ["actual", "pessimistic", "realistic", "optimistic"]},
              "level":    {"enum": ["data", "grp", "subgroup"]},
              "signs":    {"type": "array", "items": {"type": "number"}},
              "actual":   {"type": "object"},
              "projection_delta": {"type": "object"},
              "year":     {"type": "integer"},
              "window":   {"enum": ["current", "ytd"]},
              "kpi":      {"type": "string", "minLength": 1}
            },
            "allOf": [
              {"if": {"properties": {"kind": {"const": "kpi_trend"}}, "required": ["kind"]},
               "then": {"required": ["kpi"]}},
              {"if": {"properties": {"kind": {"const": "kpi_value"}}, "required": ["kind"]},
               "then": {"required": ["kpi"]}}
            ]
          }
        }
      }
    },

    "axes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x":  {"type": "object"},
        "y":  {"type": "object"},
        "y2": {"type": "object"}
      }
    },

    "style": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "colors":    {"type": "array", "items": {"type": "string"}},
        "color_map": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },

    "reference_lines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value"],
        "additionalProperties": false,
        "properties": {
          "value": {"type": "number"},
          "label": {"type": "string"},
          "color": {"type": "string"},
          "style": {"enum": ["solid", "dashed", "dotted"]}
        }
      }
    }
  }
}
