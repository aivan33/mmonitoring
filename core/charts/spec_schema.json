{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chart spec",
  "type": "object",
  "required": ["chart_id", "client", "title", "chart_type", "source", "period", "data"],
  "additionalProperties": false,
  "properties": {
    "chart_id": {"type": "string", "minLength": 1},
    "client":   {"type": "string", "minLength": 1},
    "title":    {"type": "string", "minLength": 1},
    "chart_type": {
      "enum": ["line", "bar", "stacked_bar", "donut", "kpi_card", "waterfall", "table"]
    },
    "source":   {"enum": ["custom", "platform"]},
    "platform_export": {"type": ["string", "null"]},
    "entity":   {"type": ["string", "null"]},
    "notes":    {"type": "string"},

    "period": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind":   {"enum": ["current_month", "ytd", "ltm", "month_offset",
                            "full_year", "explicit", "range"]},
        "offset": {"type": "integer"},
        "year":   {"type": "integer"},
        "month":  {"type": "integer", "minimum": 1, "maximum": 12},
        "start":  {"type": "string"},
        "end":    {"type": "string"},
        "months": {"type": "integer", "minimum": 1}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "full_year"}}},
         "then": {"required": ["year"]}},
        {"if": {"properties": {"kind": {"const": "explicit"}}},
         "then": {"required": ["year", "month"]}},
        {"if": {"properties": {"kind": {"const": "month_offset"}}},
         "then": {"required": ["offset"]}},
        {"if": {"properties": {"kind": {"const": "range"}}},
         "then": {"required": ["start", "end"]}}
      ]
    },

    "data": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label", "query"],
        "additionalProperties": false,
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "query": {
            "type": "object",
            "required": ["kind"],
            "additionalProperties": false,
            "properties": {
              "kind":     {"enum": ["trend", "value", "aggregation"]},
              "data":     {"oneOf": [
                {"type": "string"},
                {"type": "array", "items": {"type": "string"}, "minItems": 1}
              ]},
              "grp":      {"type": ["string", "null"]},
              "subgroup": {"type": ["string", "null"]},
              "scenario": {"enum": ["actual", "pessimistic", "realistic", "optimistic"]},
              "level":    {"enum": ["data", "grp", "subgroup"]},
              "signs":    {"type": "array", "items": {"type": "number"}}
            }
          }
        }
      }
    },

    "axes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x":  {"type": "object"},
        "y":  {"type": "object"},
        "y2": {"type": "object"}
      }
    },

    "style": {"type": "object"}
  }
}
