{
  "chart_id": "kpi_gross_profit_mtd",
  "client": "cupffee",
  "title": "Gross Profit MTD",
  "chart_type": "gauge",
  "source": "custom",
  "period": {"kind": "current_month"},

  "data": [
    {
      "label": "Actual",
      "query": {
        "kind": "trend",
        "data": ["Sales", "Cost of Sales"],
        "signs": [1, -1],
        "scenario": "actual"
      }
    },
    {
      "label": "Budget (Realistic)",
      "query": {
        "kind": "trend",
        "data": ["Sales", "Cost of Sales"],
        "signs": [1, -1],
        "scenario": "realistic"
      }
    }
  ],

  "gauge": {"start": 0},

  "notes": "Half-donut gauge: actual MTD gross profit vs realistic budget. Gross Profit = Sales − Cost of Sales (matches the slide-4 definition; Production Costs are reported separately under Direct Production)."
}
