{
  "chart_id": "cash_breakdown_rolling",
  "client": "cupffee",
  "title": "Cash Breakdown — Rolling 2026",
  "chart_type": "stacked_bar",
  "source": "custom",
  "period": {"kind": "full_year", "year": 2026},

  "data": [
    {
      "label": "Cash from Clients",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": "Cash from Sales",
        "scenario": "actual",
        "fallback_scenario": "realistic"
      }
    },
    {
      "label": "Materials",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": "Purchased direct material",
        "scenario": "actual",
        "fallback_scenario": "realistic"
      }
    },
    {
      "label": "Other (Op)",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Operating Activities",
        "grp": [
          "Cash paid to suppliers",
          "Payments to personnel (excl. R&D cap)",
          "VAT & Refunds",
          "Taxes paid / redeemed, net",
          "Other payments/proceeds, net (taxes, FX gains/losses)"
        ],
        "scenario": "actual",
        "fallback_scenario": "realistic"
      }
    },
    {
      "label": "Financing",
      "query": {
        "kind": "trend",
        "data": "Cash Flow from Financing Activities",
        "scenario": "actual",
        "fallback_scenario": "realistic"
      }
    }
  ],

  "axes": {
    "y": {"format": "EUR_thousands"}
  },

  "style": {
    "colors": ["#2A625E", "#D87575", "#A04545", "#2DA8A0"]
  },

  "notes": "Rolling 2026 cash-flow breakdown stacked by category. Each series uses actual values where present (Jan-Mar) and falls back to the realistic budget for Apr-Dec. Positive segments stack up, negative stack down. PPE/Investing series dropped — always 0 in 2026 plan."
}
