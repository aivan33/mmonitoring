{
  "chart_id": "cash_balances_rolling",
  "client": "cupffee",
  "title": "Cash Balances — Rolling 2026",
  "chart_type": "bar_projection",
  "source": "custom",
  "period": {"kind": "full_year", "year": 2026},

  "data": [
    {
      "label": "Actual",
      "query": {
        "kind": "projection",
        "actual": {
          "kind": "trend",
          "data": "Cash and cash equivalents",
          "grp": "Cash and cash equivalents",
          "subgroup": "Cash and cash equivalents",
          "scenario": "actual"
        },
        "projection_delta": {
          "kind": "trend",
          "data": [
            "Cash Flow from Operating Activities",
            "Cash Flow from Investing Activities",
            "Cash Flow from Financing Activities"
          ],
          "scenario": "realistic"
        }
      }
    }
  ],

  "axes": {
    "y": {"format": "EUR_thousands"}
  },

  "style": {
    "colors": ["#E67D5A", "#2A625E"]
  },

  "notes": "Rolling cash projection: actual closing cash for Jan-Mar 2026 (orange), then projected forward Apr-Dec by adding the realistic-scenario monthly net cash change (operating + investing + financing) to the last actual baseline. Projected months render in dark teal."
}
